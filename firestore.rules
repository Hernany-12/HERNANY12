rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Identifiers and data type helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidEngineer(data) {
      return data.keys().hasAll(['id', 'name', 'values', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.id is string
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.values is map
        && data.createdAt is string
        && data.updatedAt is string;
    }

    // Term schema matching typescript { id, name }
    function isValidTerm(data) {
      return data.keys().hasAll(['id', 'name'])
        && data.keys().size() == 2
        && data.id is string
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 200;
    }

    // Rules for Engineers Collection
    match /engineers/{engineerId} {
      allow get, list: if true;
      allow create: if isValidId(engineerId) && isValidEngineer(incoming());
      allow update: if isValidId(engineerId) && isValidEngineer(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(engineerId);
    }

    // Rules for Terms Collection
    match /terms/{termId} {
      allow get, list: if true;
      allow create: if isValidId(termId) && isValidTerm(incoming());
      allow update: if isValidId(termId) && isValidTerm(incoming());
      allow delete: if isValidId(termId);
    }
  }
}
